rules_version = '2';

// DakokuLess 本番用ルール
// 適用方法: Firebaseコンソール → Firestore Database → ルール → 全文置き換え → 公開
// 併せて Authentication → ログイン方法 → 「匿名」を有効にしてください。
// アクセス制御: 認証済み(匿名含む)ユーザーのみ。チームの秘匿は推測困難なチームIDで担保します。
// チームIDは十分に長いランダムな文字列(例: eigyo1-x7k2m9pq)にしてください。

service cloud.firestore {
  match /databases/{database}/documents {
    match /teams/{teamId}/{document=**} {
      allow read, write: if request.auth != null;
    }
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
